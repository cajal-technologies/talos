---
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  active?: "projects" | "specs";
  wide?: boolean;
}
const { title, active, wide } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
</head>
<body>
<div class="topbar">
  <div class="brand"><a href={import.meta.env.BASE_URL || "/"}>Talos · verification report</a></div>
  <nav>
    <a href={(import.meta.env.BASE_URL || "/")} class={active === "projects" ? "active" : ""}>Projects</a>
    <a href={(import.meta.env.BASE_URL || "/") + "specs.html"} class={active === "specs" ? "active" : ""}>All specs</a>
  </nav>
</div>
<main class={"container" + (wide ? " wide" : "")}>
  <slot />
  <footer class="site">Generated by <code>talos-report</code> from <code>verifier extract</code> artifacts.</footer>
</main>
<script>
  // Deep-link auto-expand: when the URL hash points at a line inside a
  // collapsed source file (`#file-foo-L42`), open its <details> and
  // scroll to the line.
  function openHashTarget() {
    const hash = location.hash;
    if (!hash) return;
    const el = document.getElementById(hash.slice(1));
    if (!el) return;
    let p: HTMLElement | null = el.parentElement;
    while (p) {
      if (p.tagName === "DETAILS") (p as HTMLDetailsElement).open = true;
      p = p.parentElement;
    }
    setTimeout(() => el.scrollIntoView({ block: "center" }), 30);
  }
  window.addEventListener("hashchange", openHashTarget);
  window.addEventListener("load", openHashTarget);
</script>
</body>
</html>
